ANCHOR_PROVIDER_URL=https://api.devnet.solana.com
ANCHOR_WALLET=~/.config/solana/id.json

# Optional: admin wallet (if empty, deployer wallet is used)
INITIAL_ADMIN=

# Presale initialize params
PRESALE_START_TS=1777262400
PRESALE_END_TS=1782496800
MIN_PURCHASE_MICRO_USD=10000000
SOL_USD_PRICE_UPDATE=7UVimffxr9ow1uXYxsr4LHAcV58mLzhmwaeKvJ1pjLiE

# Mint + allocation params
TOKEN_DECIMALS=9
TOTAL_SUPPLY_TOKENS=10000000000
PRESALE_ALLOCATION_TOKENS=1500000000
MINT_KEYPAIR_PATH=./luvia-mint.json

# Optional: use an already deployed mint and skip local keypair mint management
EXISTING_TOKEN_MINT=

# PDA seed overrides (normally leave as defaults)
PRESALE_SEED=presale_config
TREASURY_SEED=treasury

# Optional flow toggles for deploy script
SKIP_MINT_CREATION=false
SKIP_MINT_SUPPLY=false
SKIP_INITIALIZE=false
SKIP_VAULT_FUND=false
RENOUNCE_MINT_AUTHORITY=false
