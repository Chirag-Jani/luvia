# --- Reown AppKit ---
# Get your project id from https://dashboard.reown.com
VITE_REOWN_PROJECT_ID=

# --- Solana ---
# 'devnet' or 'mainnet-beta'
VITE_SOLANA_CLUSTER=devnet

# Optional custom RPC (Helius / QuickNode / Triton). Falls back to the public
# Solana endpoint for the selected cluster if unset. Strongly recommended for
# production — public devnet is heavily rate-limited.
VITE_SOLANA_RPC_URL=

# Deployed LUVIA presale program id. Defaults to the declare_id! in the
# Anchor program; override only if you deploy to a fresh program id.
VITE_LUVIA_PROGRAM_ID=H6DXYanZ9uiDsUqwsXu7GKNH1E1WHdqKoJr9JqqzA8cP

# --- Pyth ---
# Override only if you self-host a Hermes instance.
VITE_HERMES_ENDPOINT=https://hermes.pyth.network

# --- Presale metadata ---
# Optional presale end date (ISO 8601). Used only for the countdown UI.
# If unset the countdown falls back to "now + 60 days".
VITE_PRESALE_END_DATE=
